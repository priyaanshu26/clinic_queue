# Flutter/Dart/Pub
.dart_tool/
.pub/
.pub-cache/
.flutter-plugins
.flutter-plugins-dependencies
.packages
pubspec.lock
build/
coverage/
**/doc/api/
**/ios/Flutter/.last_build_id
migrate_working_dir/

# Android
android/.gradle/
android/.cxx/
android/local.properties
android/key.properties
android/gradlew
android/gradlew.bat
android/captures/
android/GeneratedPluginRegistrant.java
android/**/gradle-wrapper.jar
android/**/build/
android/app/debug/
android/app/profile/
android/app/release/
**/*.keystore
**/*.jks

# Symbolication/Obfuscation
app.*.symbols
app.*.map.json

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.svn/
.swiftpm/

# Web
web/.dart_tool/
web/build/

# macOS (if enabled in future)
macos/Flutter/ephemeral/
macos/build/

# Windows (if enabled in future)
windows/Flutter/ephemeral/
windows/build/

# Linux (if enabled in future)
linux/Flutter/ephemeral/
